{
  "dataset": {
    "name": "NASA Kepler + TESS (KOI + TOI)",
    "n": 10253,
    "n_total": 17492,
    "target": "CONFIRMED exoplanet vs FALSE POSITIVE",
    "source": "NASA Exoplanet Archive \u2014 Kepler cumulative KOI + TESS TOI tables",
    "citation": "NASA Exoplanet Archive (Kepler KOI cumulative; TESS TOI). Borucki et al. 2010; Ricker et al. 2015.",
    "datasets": [
      "Kepler KOI",
      "TESS TOI"
    ]
  },
  "features": [
    {
      "key": "koi_period",
      "label": "Orbital period",
      "unit": "days",
      "note": "How long one orbit takes. Real planets span a huge range; very short periods need care."
    },
    {
      "key": "koi_duration",
      "label": "Transit duration",
      "unit": "hours",
      "note": "How long the star dims for. Must be consistent with the period and star size for a real planet."
    },
    {
      "key": "koi_depth",
      "label": "Transit depth",
      "unit": "ppm",
      "note": "How much the star's light drops. Deeper dip = bigger object crossing -- but a star-sized dip means an eclipsing binary, not a planet."
    },
    {
      "key": "koi_prad",
      "label": "Planet radius",
      "unit": "R_Earth",
      "note": "Inferred radius in Earth radii. Tens of Earth radii is star-sized -> usually a FALSE POSITIVE."
    },
    {
      "key": "koi_teq",
      "label": "Equilibrium temp",
      "unit": "K",
      "note": "Estimated temperature from the star's heat. Context for habitability, weak on its own."
    },
    {
      "key": "koi_insol",
      "label": "Insolation flux",
      "unit": "Earth=1",
      "note": "Starlight received vs Earth. Extreme values hint at very close or odd orbits."
    },
    {
      "key": "koi_model_snr",
      "label": "Signal-to-noise",
      "unit": "",
      "note": "Strength of the transit signal. Low SNR often means noise or a marginal false positive."
    },
    {
      "key": "koi_steff",
      "label": "Star temperature",
      "unit": "K",
      "note": "Host star's surface temperature."
    },
    {
      "key": "koi_slogg",
      "label": "Star surface gravity",
      "unit": "log g",
      "note": "Host star's surface gravity; helps pin down the star's size."
    },
    {
      "key": "koi_srad",
      "label": "Star radius",
      "unit": "R_Sun",
      "note": "Host star's radius. Needed to turn a transit depth into a planet size."
    },
    {
      "key": "koi_impact",
      "label": "Impact parameter",
      "unit": "",
      "note": "How centrally the object crosses the star (0 = central). Grazing (>1) transits are often false positives."
    }
  ],
